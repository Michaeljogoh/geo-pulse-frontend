# Backend API (no trailing slash). Public by design — CORS + rate limits are enforced server-side.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional branding
NEXT_PUBLIC_APP_NAME=GeoPulse Crypto Intelligence

# Firebase Web config (Phase 14) — public client identifiers, not secrets.
# Must match the backend FIREBASE_PROJECT_ID for Auth.
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=proj.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=geoip-crypto-intel
NEXT_PUBLIC_FIREBASE_APP_ID=1:123:web:abc
